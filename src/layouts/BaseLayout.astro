---
import { ClientRouter } from "astro:transitions";
import { Header } from "@/components/layout/header";
import { siteConfig } from "@/config/site.config";
import "@/styles/globals.css";
import ibmPlexSans400Url from "@fontsource/ibm-plex-sans/files/ibm-plex-sans-latin-400-normal.woff2?url";
import ibmPlexSans500Url from "@fontsource/ibm-plex-sans/files/ibm-plex-sans-latin-500-normal.woff2?url";
import bodoniModa700Url from "@fontsource/bodoni-moda/files/bodoni-moda-latin-700-normal.woff2?url";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  imageAlt?: string;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  ogImage,
  imageAlt,
} = Astro.props;

const canonicalUrl = Astro.url.href;
const resolvedOgImage = ogImage ?? siteConfig.og;
const resolvedImageAlt = imageAlt ?? siteConfig.name;

const pageTitle = title === siteConfig.title ? title : `${title} | ${siteConfig.name}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={siteConfig.keywords.join(", ")} />
    <meta name="creator" content={siteConfig.name} />
    <meta name="theme-color" content="#000000" />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="2880" />
    <meta property="og:image:height" content="1800" />
    <meta property="og:image:alt" content={resolvedImageAlt} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={siteConfig.socials.x} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <meta name="twitter:image:width" content="2880" />
    <meta name="twitter:image:height" content="1800" />
    <meta name="twitter:image:alt" content={resolvedImageAlt} />

    <!-- Preconnect to third-party origins -->
    <link rel="preconnect" href="https://us.i.posthog.com" />

    <!-- Preload critical fonts -->
    <link rel="preload" href={ibmPlexSans400Url} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={ibmPlexSans500Url} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={bodoniModa700Url} as="font" type="font/woff2" crossorigin />

    <ClientRouter />

    <!-- PostHog analytics -->
    <script>
      import posthog from "posthog-js";
      posthog.init(import.meta.env.PUBLIC_POSTHOG_KEY ?? "", {
        api_host: "https://us.i.posthog.com",
        capture_pageview: "history_change",
        capture_pageleave: true,
        capture_exceptions: true,
        debug: import.meta.env.DEV,
        person_profiles: "identified_only",
      });
    </script>
    <slot name="head" />
  </head>
  <body class="font-sans antialiased">
    <div class="flex flex-col h-full py-8 gap-4 px-4 relative bg-background min-h-dvh">
      <div class="ambient-layer absolute inset-0 z-0"></div>
      <main class="flex flex-col h-full gap-12 lg:justify-between">
        <Header client:idle />
        <div class="container mx-auto w-full h-full flex lg:items-center lg:justify-center items-start justify-start">
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>
